model Game {
  id     Int     @id @default(autoincrement())
  name   String
  genres Genre[] @relation("GameGenres")
  tags   Tag[]   @relation("GameTags")
  users  User[]  @relation("UserGames")
}

model Genre {
  id    Int    @id @default(autoincrement())
  name  String
  color String
  games Game[] @relation("GameGenres")
}

model Tag {
  id     Int    @id @default(autoincrement())
  label  String
  color  String
  games  Game[] @relation("GameTags")
  users  User[] @relation("UserTags")
}


model Account {
  id                 Int     @id @default(autoincrement())
  userId             Int
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? 
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id          Int      @id @default(autoincrement())
  
  senderId    Int
  recipient   User     @relation("InvitesReceived", fields: [recipientId], references: [id])
  recipientId Int
  messageInstance   MessageInstance? @relation(fields: [messageInstanceId], references: [id])
  messageInstanceId Int?
  status            String          @default("pending")
  createdAt   DateTime @default(now())

  sender      User     @relation("InvitesSent", fields: [senderId], references: [id])
}

model Message {
  id          Int      @id @default(autoincrement())
  content     String
  sender      User     @relation("MessagesSent", fields: [senderId], references: [id])
  senderId    Int
  recipient   User     @relation("MessagesReceived", fields: [recipientId], references: [id])
  recipientId Int
  createdAt   DateTime @default(now())
  instanceId Int

  instance MessageInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}
