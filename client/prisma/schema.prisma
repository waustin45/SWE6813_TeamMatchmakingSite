model MessageInstance {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  senderId Int
  receiverId Int
  messages Message[]
  invites  Invite[]

  user User @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

